# =============================================
# Fichiers générés par Jekyll (à ne pas versionner)
# =============================================
_site/
.sass-cache/
.jekyll-cache/
.jekyll-metadata

# =============================================
# Fichiers spécifiques à Ruby/Bundler
# =============================================
vendor/
.bundle/
Gemfile.lock

# =============================================
# Fichiers système macOS/Linux/Windows
# =============================================
.DS_Store
Thumbs.db
desktop.ini

# =============================================
# Fichiers temporaires et logs
# =============================================
*.log
*.swp
*.swo
*~
tmp/
temp/

# =============================================
# Fichiers de configuration locaux (optionnel)
# =============================================
# Ignorer les fichiers de config locale si tu en as
# (ex: _config.dev.yml)
_config*.local.yml
_config*.dev.yml

# =============================================
# Dossiers de build ou de cache
# =============================================
node_modules/
dist/
cache/

# =============================================
# Fichiers de backup ou temporaires
# =============================================
*.bak
*.backup
*.orig
*.old

# =============================================
# Exceptions pour GitHub Pages
# =============================================
# NE PAS IGNORER :
# - Le dossier _site/ est ignoré car généré par Jekyll,
#   mais GitHub Pages le régénère automatiquement.
# - Gemfile.lock est ignoré car spécifique à ton environnement local.
#   GitHub utilise sa propre version lors du déploiement.